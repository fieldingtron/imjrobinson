---
import BaseLayout from '../layouts/BaseLayout.astro'
import ArticlesContent from '../../content/posts/articles.md'
import ShowsContent from '../../content/posts/shows.md'

const pageTitle = 'Shows and Articles | Isabelle Robinson'
const pageDescription =
  'See exhibitions, awards, and published articles featuring the work of Isabelle Robinson.'
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath='/shows/'
>
  <main>
    <div class='container mt-3'>
      <h1 class='fs-1 text-center my-2'>Shows and Articles</h1>
      <h2 class='fs-2 text-center my-2'>Art Shows</h2>

      <div class='lead text-start px-md-5 fs-5 mt-3 shows'>
        <ShowsContent />
      </div>

      <h2 class='fs-2 text-center my-2'>Articles</h2>
      <div class='lead text-start px-md-5 fs-5'>
        <ArticlesContent />
      </div>
    </div>
  </main>
</BaseLayout>
