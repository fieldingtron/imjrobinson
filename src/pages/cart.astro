---
import BaseLayout from '../layouts/ToolkitLayout.astro'
const pageTitle = 'Shopping Cart | Isabelle Robinson'
const pageDescription = 'Review items in your Isabelle Robinson shopping cart before checkout.'
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath='/cart/'
  robots='noindex,nofollow'
>
  <main class='my-3'>
    <div class='container'>
      <h1 class='text-center mb-4'>Shopping Cart</h1>
      <div
        data-reflow-type='shopping-cart'
        data-reflow-success-url='/success/'
        data-reflow-cancel-url='/cancel/'
      >
      </div>
    </div>
  </main>
</BaseLayout>
