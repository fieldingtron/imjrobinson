---
import BaseLayout from '../layouts/BaseLayout.astro'
const pageTitle = 'Isabelle Robinson Art | Contemporary Assemblages, Paintings, and Photography'
const pageDescription =
  'Discover the contemporary assemblages, paintings, and photography of Isabelle Robinson and explore featured gallery collections inspired by healing, wholeness, and transformation.'
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath='/'
  ogImage='/img/broken-separated-united.jpg'
>
  <main>
    <section id='mainpic'>
      <div class='container mainpage-text'>
        <img
          class='rounded img-fluid'
          id='hero-image'
          src='/img/broken-separated-united.jpg'
          alt='Broken Separated United'
          width='2436'
          height='1125'
          loading='eager'
          fetchpriority='high'
          decoding='async'
        />
        <h1 class='text-center mainpage-text' id='introtext'>
          Broken&nbsp; -&nbsp; Separated - United
        </h1>
        <h5 class='text-capitalize text-center' id='intro2text'>
          When the broken becomes whole<br />
        </h5><a href='/gallery/' aria-label='Explore Isabelle Robinson galleries'>
          <p class='text-center fs-1 mb-0' id='gallerylink'>Explore Our Galleries</p>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
