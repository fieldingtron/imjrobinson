---
import BaseLayout from '../layouts/BaseLayout.astro'
const pageTitle = 'Order Success | Isabelle Robinson'
const pageDescription =
  'Confirmation page for successful artwork orders placed through Isabelle Robinson Art.'
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath='/success/'
  robots='noindex,nofollow'
>
  <main>
    <div class='container text-center mt-3'>
      <h1 class='fs-1 text-center my-4'>Success!</h1>
      <p class='lead text-start px-md-5'>
        You have successfully ordered!! Please check your inbox&nbsp;
        and&nbsp;expect to hear from me personally within 2 working days.
      </p>
    </div>
  </main>
</BaseLayout>
